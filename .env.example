# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Supported providers: google, nvidia, openai
LLM_PROVIDER=google

# ============================================================================
# Google Gemini (default)
# ============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash-exp

# ============================================================================
# NVIDIA AI (OpenAI-compatible)
# ============================================================================
# To use NVIDIA, set LLM_PROVIDER=nvidia
# Get API key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
OPENAI_MODEL=openai/gpt-oss-120b
# Other NVIDIA models:
# - nvidia/llama-3.1-nemotron-70b-instruct
# - meta/llama-3.1-405b-instruct
# - mistralai/mixtral-8x22b-instruct-v0.1

# ============================================================================
# OpenAI
# ============================================================================
# To use OpenAI, set LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Embedding Provider Configuration
# ============================================================================
# Supported: google, nvidia, openai
# If not set, defaults to same as LLM_PROVIDER
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/nv-embed-v1

# NVIDIA Embedding Models (from screenshot):
# - nvidia/nv-embed-v1 (Free, 2.54M params, recommended)
# - nv-embedqa-e5-v5 (6.34M params)
# - llama-nemotron-embed-1b-v2 (Multilingual, 632K params)
# - baai/bge-m3 (Multilingual)

# For NVIDIA embeddings (if different from main NVIDIA_API_KEY)
# EMBEDDING_API_KEY=nvapi-your_embedding_key
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1

# For Google embeddings
# EMBEDDING_PROVIDER=google
# EMBEDDING_MODEL=gemini-embedding-001

# For OpenAI embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# LLM Generation Parameters
# ============================================================================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TOP_P=1.0

# ============================================================================
# LangFuse Observability (optional)
# ============================================================================
# Get keys from: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ============================================================================
# Telegram Bot
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
