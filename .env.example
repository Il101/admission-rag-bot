# ============================================================================
# Telegram Bot
# ============================================================================
# Token from @BotFather
TGBOT_TOKEN=your_telegram_bot_token_here
# Telegram numeric id and @tag of the primary admin (bootstrapped on first run)
FATHER_TG_ID=your_admin_telegram_id
FATHER_TG_TAG=your_admin_username

# ============================================================================
# Database (PostgreSQL + pgvector)
# ============================================================================
# These are consumed both by the bot and by the `db` service in
# docker-compose.yml. Inside compose, POSTGRES_HOST must be `db`.
POSTGRES_USER=langchain
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_DB=langchain
# Optional: a single connection URL instead of the POSTGRES_* vars above.
# If set, the bot derives the POSTGRES_* values from it (see bot/env.py).
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ============================================================================
# pgAdmin (optional management UI, exposed on 127.0.0.1:15433)
# ============================================================================
PGADMIN_DEFAULT_EMAIL=user@domain.com
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_CONFIG_ENHANCED_COOKIE_PROTECTION=True

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Supported providers: google, nvidia, openai
LLM_PROVIDER=google

# --- Google Gemini (default) ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# --- NVIDIA AI (OpenAI-compatible) ---
# To use NVIDIA, set LLM_PROVIDER=nvidia. Get a key at https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
# OPENAI_MODEL=openai/gpt-oss-120b

# --- OpenAI ---
# To use OpenAI, set LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Generation parameters ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TOP_P=1.0

# ============================================================================
# Embedding Provider Configuration
# ============================================================================
# Supported: google, nvidia, openai. If unset, defaults to LLM_PROVIDER.
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/nv-embed-v1
# If the embedding endpoint/key differ from the main provider:
# EMBEDDING_API_KEY=nvapi-your_embedding_key
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional: truncate embedding dimensions (MUST match how the KB was indexed)
# EMBEDDING_TRUNCATE_DIMS=768

# Examples for other embedding providers:
# EMBEDDING_PROVIDER=google
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# LangFuse Observability (optional)
# ============================================================================
# Get keys from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================================
# Operational flags (optional, sensible defaults shown)
# ============================================================================
# Stream answer edits as plain text to avoid partial-HTML parse errors
SAFE_STREAM_PLAIN=true
# Soft timeout (seconds) for LLM reranking; 0 disables the timeout
RERANK_SOFT_TIMEOUT_SEC=0
# Use parent-child chunking when indexing the knowledge base
# USE_PARENT_CHILD_CHUNKING=false
# Force a full KB re-index on next start
# FORCE_REINDEX=true
